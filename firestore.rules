rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config/notebook (Singleton)
    // Fields: title (string), lastUpdated (timestamp), totalDays (int)
    //
    // Collection: days/{dayId}
    // Fields: id (string), title (string), order (int), cellRange (list)
    //
    // Collection: content/{dayId}
    // Fields: cells (list of objects)
    //
    // Collection: exercises/{dayId}
    // Fields: exercises (list of objects)
    //
    // Collection: users/{userId}/progress/{exerciseId}
    // Fields: completed (bool), userCode (string), lastOutput (string), timestamp (timestamp)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "andrezbuitrago82@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Notebook Config
    match /config/notebook {
      allow read: if true; // Publicly readable to see the bootcamp
      allow write: if isAdmin();
    }

    // Day Metadata
    match /days/{dayId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Day Content (Cells)
    match /content/{dayId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // AI Exercises
    match /exercises/{dayId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Progress
    match /users/{userId}/progress/{exerciseId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
