rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: config/notebook (Singleton)
    // Fields: title (string), lastUpdated (timestamp), totalDays (int)
    //
    // Collection: days/{dayId}
    // Fields: id (string), title (string), order (int), cellRange (list)
    //
    // Collection: content/{dayId}
    // Fields: cells (list of objects)
    //
    // Collection: exercises/{dayId}
    // Fields: exercises (list of objects)
    //
    // Collection: users/{userId}/progress/{exerciseId}
    // Fields: completed (bool), userCode (string), lastOutput (string), timestamp (timestamp)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "andrezbuitrago82@gmail.com" ||
          exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Admins Collection
    match /admins/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Groups Management
    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
      
      // Scoped Config
      match /config/notebook {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Scoped Days
      match /days/{dayId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Scoped Content
      match /content/{dayId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      // Scoped Exercises
      match /exercises/{dayId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // User Progress (Scoped by user and group for isolation)
    match /users/{userId}/groups/{groupId}/progress/{exerciseId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
